@page "/admin/folders"
@model FoldersModel
@{
    ViewData["Title"] = "浏览文件夹";
}

<style>
    .page-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 28px;
        animation: fadeUp 0.5s ease-out both;
    }

    .page-title {
        font-family: var(--font-display);
        font-size: 28px;
        font-weight: 400;
        letter-spacing: -0.03em;
    }

    .page-count {
        font-size: 13px;
        color: var(--text-muted);
    }

    .stats-row {
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
        animation: fadeUp 0.5s ease-out both;
        animation-delay: 0.05s;
    }

    .stat-pill {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 16px 24px;
        flex: 1;
        text-align: center;
        transition: box-shadow var(--transition);
    }

    .stat-pill:hover { box-shadow: var(--shadow-sm); }

    .stat-pill .num {
        font-family: var(--font-display);
        font-size: 24px;
        font-weight: 300;
        color: var(--text);
    }

    .stat-pill .label {
        font-size: 11px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--text-muted);
        margin-top: 4px;
    }

    .folders-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        animation: fadeUp 0.5s ease-out both;
        animation-delay: 0.1s;
    }

    .folders-layout.full-tree { grid-template-columns: 1fr; }

    .panel {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .panel-tree {
        max-height: 72vh;
        overflow-y: auto;
    }

    .panel-detail {
        max-height: 72vh;
        overflow-y: auto;
        padding: 28px 32px;
        position: sticky;
        top: 80px;
    }

    .tree-node {
        display: flex;
        align-items: center;
        padding: 12px 20px;
        border-bottom: 1px solid var(--border);
        cursor: pointer;
        transition: background var(--transition);
        text-decoration: none;
        color: inherit;
    }

    .tree-node:last-child { border-bottom: none; }
    .tree-node:hover { background: var(--accent-light); }
    .tree-node.active { background: var(--accent-light); border-left: 3px solid var(--accent); }

    .tree-name {
        font-size: 14px;
        font-weight: 500;
        color: var(--text);
        flex: 1;
    }

    .tree-name .deleted-tag {
        font-size: 11px;
        font-weight: 400;
        color: var(--danger);
        margin-left: 6px;
    }

    .tree-count {
        font-size: 12px;
        color: var(--text-muted);
        font-family: var(--font-mono);
        margin-right: 12px;
    }

    .tree-date {
        font-size: 11.5px;
        color: var(--text-muted);
    }

    .detail-title {
        font-family: var(--font-display);
        font-size: 20px;
        font-weight: 500;
        letter-spacing: -0.02em;
        margin-bottom: 12px;
    }

    .detail-meta {
        font-size: 12.5px;
        color: var(--text-muted);
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 20px;
    }

    .detail-section-title {
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--text-muted);
        margin-bottom: 12px;
    }

    .note-link {
        font-size: 13px;
        color: var(--accent);
        text-decoration: none;
        font-weight: 500;
    }

    .note-link:hover { opacity: 0.7; }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-muted);
        font-size: 14px;
    }

    .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
    }

    .badge-ok { background: var(--success-bg); color: var(--accent); }
    .badge-del { background: var(--danger-bg); color: var(--danger); }

    @@media (max-width: 768px) {
        .folders-layout { grid-template-columns: 1fr; }
        .stats-row { flex-direction: column; }
    }
</style>

<div class="page-header">
    <h1 class="page-title">文件夹</h1>
    <span class="page-count">只读浏览 · @Model.Tree.Count 个</span>
</div>

@if (Model.Tree.Any())
{
    var totalNotes = Model.Tree.Sum(n => n.NoteCount);
    var totalActive = Model.Tree.Sum(n => n.ActiveNoteCount);

    <div class="stats-row">
        <div class="stat-pill">
            <div class="num">@Model.Tree.Count</div>
            <div class="label">文件夹</div>
        </div>
        <div class="stat-pill">
            <div class="num">@totalActive</div>
            <div class="label">活跃笔记</div>
        </div>
        <div class="stat-pill">
            <div class="num">@(totalNotes - totalActive)</div>
            <div class="label">已删除</div>
        </div>
    </div>
}

@if (Model.SelectedFolder != null)
{
    <div class="folders-layout">
        <div class="panel panel-tree">
            @foreach (var node in Model.Tree)
            {
                var indentPx = node.Depth * 24;
                var isActive = node.Id == Model.SelectedFolder.Id;
                <a class="tree-node @(isActive ? "active" : "")" href="/admin/folders?folderId=@node.Id">
                    <span style="width:@(indentPx)px;display:inline-block;flex-shrink:0;"></span>
                    <span class="tree-name">
                        @node.Name
                        @if (node.IsDeleted)
                        {
                            <span class="deleted-tag">已删除</span>
                        }
                    </span>
                    <span class="tree-count">@node.ActiveNoteCount/@node.NoteCount</span>
                    <span class="tree-date">@node.UpdatedAt.ToString("MM-dd")</span>
                </a>
            }
        </div>

        <div class="panel panel-detail">
            <h2 class="detail-title">@Model.SelectedFolder.Name</h2>
            <div class="detail-meta">
                <span>v@(Model.SelectedFolder.Version)</span>
                <span>@Model.SelectedFolder.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                <span>@Model.SelectedFolder.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                @if (Model.SelectedFolder.IsDeleted)
                {
                    <span style="color:var(--danger);">已删除</span>
                }
            </div>

            <div class="detail-section-title">文件夹内笔记 · @Model.SelectedFolderNotes.Count 篇</div>

            @if (Model.SelectedFolderNotes.Any())
            {
                <table>
                    <thead>
                        <tr><th>标题</th><th>状态</th><th>更新</th><th></th></tr>
                    </thead>
                    <tbody>
                        @foreach (var note in Model.SelectedFolderNotes)
                        {
                            <tr>
                                <td style="font-weight:500;">@note.Title</td>
                                <td>
                                    @if (note.IsDeleted)
                                    {
                                        <span class="badge badge-del">已删除</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-ok">正常</span>
                                    }
                                </td>
                                <td style="font-size:13px;color:var(--text-muted);">@note.UpdatedAt.ToString("MM-dd HH:mm")</td>
                                <td>
                                    <a href="/admin/notes?noteId=@note.Id&folderId=@Model.SelectedFolder.Id" class="note-link">查看</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">此文件夹暂无笔记</div>
            }
        </div>
    </div>
}
else if (Model.Tree.Any())
{
    <div class="folders-layout full-tree">
        <div class="panel panel-tree">
            @foreach (var node in Model.Tree)
            {
                var indentPx = node.Depth * 24;
                <a class="tree-node" href="/admin/folders?folderId=@node.Id">
                    <span style="width:@(indentPx)px;display:inline-block;flex-shrink:0;"></span>
                    <span class="tree-name">
                        @node.Name
                        @if (node.IsDeleted)
                        {
                            <span class="deleted-tag">已删除</span>
                        }
                    </span>
                    <span class="tree-count">@node.ActiveNoteCount/@node.NoteCount</span>
                    <span class="tree-date">@node.UpdatedAt.ToString("MM-dd")</span>
                </a>
            }
        </div>
    </div>
}
else
{
    <div class="empty-state">暂无文件夹</div>
}
