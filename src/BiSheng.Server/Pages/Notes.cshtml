@page "/admin/notes"
@model NotesModel
@{
    ViewData["Title"] = "笔记管理";
}

<style>
    .page-header {
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        margin-bottom: 28px;
        animation: fadeUp 0.5s ease-out both;
    }

    .page-title {
        font-family: var(--font-display);
        font-size: 28px;
        font-weight: 400;
        letter-spacing: -0.03em;
    }

    .page-count {
        font-size: 13px;
        color: var(--text-muted);
    }

    .filter-bar {
        display: flex;
        gap: 12px;
        align-items: center;
        margin-bottom: 24px;
        flex-wrap: wrap;
        animation: fadeUp 0.5s ease-out both;
        animation-delay: 0.05s;
    }

    .filter-bar select {
        padding: 7px 12px;
        font-family: var(--font-body);
        font-size: 13.5px;
        color: var(--text);
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        cursor: pointer;
        transition: border-color var(--transition);
    }

    .filter-bar select:focus {
        border-color: var(--accent);
        outline: none;
    }

    .filter-check {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 13px;
        color: var(--text-secondary);
        cursor: pointer;
    }

    .filter-check input[type="checkbox"] {
        width: 15px;
        height: 15px;
        accent-color: var(--accent);
    }

    .notes-layout {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
        animation: fadeUp 0.5s ease-out both;
        animation-delay: 0.1s;
    }

    .notes-layout.full-list { grid-template-columns: 1fr; }

    .panel {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
    }

    .panel-list {
        max-height: 72vh;
        overflow-y: auto;
    }

    .panel-detail {
        max-height: 72vh;
        overflow-y: auto;
        padding: 28px 32px;
        position: sticky;
        top: 80px;
    }

    .note-row {
        display: block;
        padding: 14px 24px;
        border-bottom: 1px solid var(--border);
        cursor: pointer;
        transition: background var(--transition);
        text-decoration: none;
        color: inherit;
    }

    .note-row:last-child { border-bottom: none; }
    .note-row:hover { background: var(--accent-light); }
    .note-row.active { background: var(--accent-light); border-left: 3px solid var(--accent); }

    .note-row-title {
        font-size: 14px;
        font-weight: 500;
        color: var(--text);
        margin-bottom: 3px;
    }

    .note-row-meta {
        font-size: 12px;
        color: var(--text-muted);
        display: flex;
        gap: 12px;
    }

    .badge {
        display: inline-block;
        padding: 2px 8px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
    }

    .badge-ok { background: var(--success-bg); color: var(--accent); }
    .badge-del { background: var(--danger-bg); color: var(--danger); }

    .detail-title {
        font-family: var(--font-display);
        font-size: 22px;
        font-weight: 500;
        letter-spacing: -0.02em;
        margin-bottom: 12px;
    }

    .detail-meta {
        font-size: 12.5px;
        color: var(--text-muted);
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        padding-bottom: 16px;
        border-bottom: 1px solid var(--border);
        margin-bottom: 20px;
    }

    .detail-meta span { white-space: nowrap; }

    .note-content {
        white-space: pre-wrap;
        word-break: break-word;
        font-family: var(--font-mono);
        font-size: 13px;
        line-height: 1.7;
        color: var(--text-secondary);
        background: var(--bg);
        padding: 20px 24px;
        border-radius: var(--radius);
        border: 1px solid var(--border);
        max-height: 50vh;
        overflow-y: auto;
    }

    .image-gallery {
        margin-top: 24px;
        padding-top: 20px;
        border-top: 1px solid var(--border);
    }

    .image-gallery h4 {
        font-family: var(--font-display);
        font-size: 15px;
        font-weight: 500;
        margin-bottom: 14px;
        color: var(--text);
    }

    .image-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
        gap: 10px;
    }

    .image-thumb {
        position: relative;
        border-radius: var(--radius);
        overflow: hidden;
        border: 1px solid var(--border);
        cursor: pointer;
        transition: all var(--transition);
        aspect-ratio: 1;
    }

    .image-thumb:hover {
        box-shadow: var(--shadow-md);
        transform: scale(1.02);
    }

    .image-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }

    .image-thumb .img-info {
        position: absolute;
        bottom: 0; left: 0; right: 0;
        background: rgba(0,0,0,0.6);
        color: #fff;
        font-size: 10.5px;
        font-family: var(--font-mono);
        padding: 4px 6px;
    }

    .image-modal {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.9);
        z-index: 1000;
        justify-content: center;
        align-items: center;
        cursor: zoom-out;
    }

    .image-modal.active { display: flex; }
    .image-modal img { max-width: 92vw; max-height: 92vh; border-radius: var(--radius); }

    .empty-state {
        text-align: center;
        padding: 60px 20px;
        color: var(--text-muted);
        font-size: 14px;
    }

    @@media (max-width: 768px) {
        .notes-layout { grid-template-columns: 1fr; }
    }
</style>

<div class="page-header">
    <h1 class="page-title">笔记</h1>
    <span class="page-count">@Model.Notes.Count 篇</span>
</div>

<form method="get" class="filter-bar" id="filterForm">
    <select name="folderId" onchange="document.getElementById('filterForm').submit()">
        <option value="">全部文件夹</option>
        @foreach (var folder in Model.Folders)
        {
            <option value="@folder.Id" selected="@(folder.Id == Model.FilterFolderId ? "selected" : null)">
                @folder.Name
            </option>
        }
    </select>
    <label class="filter-check">
        <input type="checkbox" name="showDeleted" value="true"
               checked="@Model.ShowDeleted"
               onchange="document.getElementById('filterForm').submit()" />
        显示已删除
    </label>
    @if (Model.FilterFolderId != null || Model.ShowDeleted)
    {
        <a href="/admin/notes" class="btn btn-secondary btn-sm">清除筛选</a>
    }
</form>

@if (Model.SelectedNote != null)
{
    <div class="notes-layout">
        <div class="panel panel-list">
            @foreach (var note in Model.Notes)
            {
                <a class="note-row @(note.Id == Model.SelectedNote.Id ? "active" : "")"
                   href="?folderId=@(Model.FilterFolderId?.ToString() ?? "")&noteId=@note.Id&showDeleted=@Model.ShowDeleted.ToString().ToLower()">
                    <div class="note-row-title">@note.Title</div>
                    <div class="note-row-meta">
                        <span>@note.FolderName</span>
                        <span>@note.UpdatedAt.ToString("MM-dd HH:mm")</span>
                        <span>v@(note.Version)</span>
                        @if (note.IsDeleted)
                        {
                            <span class="badge badge-del">已删除</span>
                        }
                    </div>
                </a>
            }
        </div>

        <div class="panel panel-detail">
            <h2 class="detail-title">@Model.SelectedNote.Title</h2>
            <div class="detail-meta">
                <span>@(Model.Folders.FirstOrDefault(f => f.Id == Model.SelectedNote.FolderId)?.Name ?? "未知文件夹")</span>
                <span>v@(Model.SelectedNote.Version)</span>
                <span>@Model.SelectedNote.CreatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                <span>@Model.SelectedNote.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</span>
                @if (Model.SelectedNote.IsDeleted)
                {
                    <span class="badge badge-del">已删除</span>
                }
            </div>
            <div class="note-content">@Model.SelectedNote.Content</div>

            @if (Model.NoteImages.Any())
            {
                <div class="image-gallery">
                    <h4>关联图片 <span class="text-muted" style="font-weight:400;">@Model.NoteImages.Count 张</span></h4>
                    <div class="image-grid">
                        @foreach (var img in Model.NoteImages)
                        {
                            var sizeKb = img.FileSize / 1024.0;
                            <div class="image-thumb" onclick="showImageModal('/admin/notes?handler=Image&id=@img.Id')">
                                <img src="/admin/notes?handler=Image&id=@img.Id" alt="@img.FileName" loading="lazy" />
                                <div class="img-info">
                                    @img.Extension.TrimStart('.').ToUpper() · @((sizeKb < 1024) ? $"{sizeKb:F0}KB" : $"{sizeKb / 1024:F1}MB")
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
}
else if (Model.Notes.Any())
{
    <div class="notes-layout full-list">
        <div class="panel panel-list">
            @foreach (var note in Model.Notes)
            {
                <a class="note-row"
                   href="/admin/notes?noteId=@note.Id@(Model.FilterFolderId.HasValue ? "&folderId=" + Model.FilterFolderId : "")&showDeleted=@Model.ShowDeleted.ToString().ToLower()">
                    <div style="display:flex;justify-content:space-between;align-items:center;">
                        <div class="note-row-title">@note.Title</div>
                        <span class="badge @(note.IsDeleted ? "badge-del" : "badge-ok")">@(note.IsDeleted ? "已删除" : "正常")</span>
                    </div>
                    <div class="note-row-meta">
                        <span>@note.FolderName</span>
                        <span>@note.UpdatedAt.ToString("MM-dd HH:mm")</span>
                        <span>v@(note.Version)</span>
                    </div>
                </a>
            }
        </div>
    </div>
}
else
{
    <div class="empty-state">暂无笔记</div>
}

<div class="image-modal" id="imageModal" onclick="this.classList.remove('active')">
    <img id="modalImg" src="" alt="" />
</div>
<script>
    function showImageModal(url) {
        document.getElementById('modalImg').src = url;
        document.getElementById('imageModal').classList.add('active');
    }
</script>
