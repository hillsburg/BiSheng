@page "/admin/keys"
@model KeysModel
@{
    ViewData["Title"] = "API Key 管理";
}

<style>
    .page-header {
        margin-bottom: 28px;
        animation: fadeUp 0.5s ease-out both;
    }

    .page-title {
        font-family: var(--font-display);
        font-size: 28px;
        font-weight: 400;
        letter-spacing: -0.03em;
        margin-bottom: 4px;
    }

    .page-subtitle {
        font-size: 14px;
        color: var(--text-muted);
    }

    .create-section {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        padding: 32px 36px;
        margin-bottom: 20px;
        animation: fadeUp 0.5s ease-out both;
        animation-delay: 0.05s;
    }

    .create-section h3 {
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 500;
        margin-bottom: 16px;
    }

    .create-form {
        display: flex;
        gap: 12px;
        align-items: flex-end;
    }

    .create-form .form-group {
        flex: 1;
        margin-bottom: 0;
    }

    .new-key-alert {
        background: var(--success-bg);
        border: 1px solid var(--success-border);
        border-radius: var(--radius);
        padding: 16px 20px;
        margin-bottom: 20px;
        animation: fadeUp 0.5s ease-out both;
    }

    .new-key-alert p {
        font-size: 13px;
        color: var(--accent);
        font-weight: 500;
        margin-bottom: 8px;
    }

    .list-section {
        background: var(--bg-elevated);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
        overflow: hidden;
        animation: fadeUp 0.5s ease-out both;
        animation-delay: 0.1s;
    }

    .list-header {
        padding: 20px 24px 0;
    }

    .list-header h3 {
        font-family: var(--font-display);
        font-size: 16px;
        font-weight: 500;
    }

    .key-status {
        display: inline-flex;
        align-items: center;
        gap: 5px;
        font-size: 12px;
        font-weight: 500;
    }

    .key-status-dot {
        width: 7px;
        height: 7px;
        border-radius: 50%;
    }

    .key-status-dot.active { background: var(--accent); }
    .key-status-dot.inactive { background: var(--text-muted); }

    .key-actions {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        align-items: center;
        justify-content: flex-end;
    }

    .key-actions form { display: inline; }

    .rename-inline {
        display: flex;
        gap: 6px;
        align-items: center;
    }

    .rename-inline input {
        width: 140px;
        padding: 5px 8px;
        font-size: 12.5px;
        margin: 0;
    }

    .empty-state {
        text-align: center;
        padding: 48px 20px;
        color: var(--text-muted);
        font-size: 14px;
    }

    @@media (max-width: 900px) {
        table .col-hide-sm { display: none; }
        .rename-inline { flex-direction: column; align-items: stretch; }
        .rename-inline input { width: 100%; }
    }
</style>

<div class="page-header">
    <h1 class="page-title">API Keys</h1>
    <p class="page-subtitle">管理客户端连接密钥；明文仅在生成时显示一次</p>
</div>

@if (!string.IsNullOrEmpty(Model.NewKeyValue))
{
    <div class="new-key-alert">
        <p>
            @(string.IsNullOrEmpty(Model.NewKeyDeviceName)
                ? "新 Key 已生成 — 请立即复制保存，此值仅显示一次"
                : $"「{Model.NewKeyDeviceName}」的 Key 已生成 — 请立即复制保存，此值仅显示一次")
        </p>
        <div class="key-value" id="newApiKeyValue">@Model.NewKeyValue</div>
        <button type="button" class="btn btn-secondary btn-sm" style="margin-top:10px;"
                onclick="navigator.clipboard.writeText(document.getElementById('newApiKeyValue').textContent).then(()=>this.textContent='已复制').catch(()=>{})">
            复制 Key
        </button>
    </div>
}

@if (!string.IsNullOrEmpty(Model.SuccessMessage))
{
    <div class="alert alert-success">@Model.SuccessMessage</div>
}

@if (!string.IsNullOrEmpty(Model.ErrorMessage))
{
    <div class="alert alert-danger">@Model.ErrorMessage</div>
}

<div class="create-section">
    <h3>生成新 Key</h3>
    <form method="post" asp-page-handler="Create" class="create-form">
        <div class="form-group">
            <label>设备名称</label>
            <input asp-for="NewDeviceName" required placeholder="例如：办公室电脑、手机" />
        </div>
        <button type="submit" class="btn btn-primary">生成</button>
    </form>
</div>

<div class="list-section">
    <div class="list-header">
        <h3>已有的 Key</h3>
    </div>

    @if (Model.Keys.Any())
    {
        <table>
            <thead>
                <tr>
                    <th>设备名称</th>
                    <th>最近使用</th>
                    <th class="col-hide-sm">创建时间</th>
                    <th>状态</th>
                    <th style="text-align:right;">操作</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var key in Model.Keys)
                {
                    <tr>
                        <td style="font-weight:500;">
                            <form method="post" asp-page-handler="Rename" class="rename-inline">
                                <input type="hidden" name="RenameKeyId" value="@key.Id" />
                                <input type="text" name="RenameDeviceName" value="@key.DeviceName" maxlength="128" required aria-label="设备名称" />
                                <button type="submit" class="btn btn-secondary btn-sm">改名</button>
                            </form>
                        </td>
                        <td style="color:var(--text-muted);font-size:13px;">
                            @(key.LastUsedAt.HasValue ? IndexModel.FormatUtcLocal(key.LastUsedAt.Value) : "从未")
                        </td>
                        <td class="col-hide-sm" style="color:var(--text-muted);font-size:13px;">
                            @IndexModel.FormatUtcLocal(key.CreatedAt)
                        </td>
                        <td>
                            @if (key.IsActive)
                            {
                                <span class="key-status">
                                    <span class="key-status-dot active"></span>
                                    活跃
                                </span>
                            }
                            else
                            {
                                <span class="key-status">
                                    <span class="key-status-dot inactive"></span>
                                    已吊销
                                </span>
                            }
                        </td>
                        <td style="text-align:right;">
                            <div class="key-actions">
                                @if (key.IsActive)
                                {
                                    <form method="post" asp-page-handler="Revoke">
                                        <input type="hidden" name="keyId" value="@key.Id" />
                                        <button type="submit" class="btn btn-danger btn-sm"
                                                onclick="return confirm('吊销后该设备将无法同步，确定继续？')">
                                            吊销
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <form method="post" asp-page-handler="Delete">
                                        <input type="hidden" name="keyId" value="@key.Id" />
                                        <button type="submit" class="btn btn-secondary btn-sm"
                                                onclick="return confirm('确定要永久删除此 Key 吗？')">
                                            删除
                                        </button>
                                    </form>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
    else
    {
        <div class="empty-state">暂无 API Key。生成一把后，到 Latte「同步设置」中粘贴即可连接。</div>
    }
</div>
