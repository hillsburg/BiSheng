{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "BiSheng.Server": "Information",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore.SignalR": "Warning"
    }
  },
  "Kestrel": {
    "EndPoints": {
      "Http": {
        "Url": "http://127.0.0.1:8090"
      }
    }
  },
  "Cors": {
    "AllowAnyOrigin": false,
    "AllowedOrigins": []
  },
  "Cookies": {
    "SecureAlways": true
  },
  "ImageGc": {
    "OrphanGraceDays": 7,
    "OrphanDryRun": false
  }
}
