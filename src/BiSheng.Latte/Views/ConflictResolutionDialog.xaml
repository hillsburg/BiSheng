<Window
    x:Class="BiSheng.Latte.Views.ConflictResolutionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="同步冲突解决"
    Width="1000"
    Height="700"
    MinWidth="800"
    MinHeight="500"
    Background="{DynamicResource Brush.BgCanvas}"
    WindowStartupLocation="CenterOwner">

    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource WindowHeaderBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource WindowTitleText}" Text="同步冲突解决" />
                <TextBlock
                    x:Name="ConflictCountText"
                    Margin="0,4,0,0"
                    Style="{StaticResource WindowSubtitleText}"
                    Text="检测到 1 个未解决的冲突" />
                <TextBlock
                    Margin="0,8,0,0"
                    Style="{StaticResource WindowHintText}"
                    Text="本地和远端同时修改了同一笔记，请选择保留哪个版本，或手动合并两者内容。" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource WindowFooterBorder}">
            <DockPanel>
                <StackPanel Margin="-8,0,0,0" DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button
                        x:Name="PrevButton"
                        Click="OnPrev"
                        Content="← 上一个"
                        Style="{StaticResource DialogButtonNeutral}" />
                    <Button
                        x:Name="NextButton"
                        Click="OnNext"
                        Content="下一个 →"
                        Style="{StaticResource DialogButtonNeutral}" />
                </StackPanel>

                <StackPanel Margin="-8,0,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Click="OnKeepLocal"
                        Content="保留本地版本"
                        Style="{StaticResource DialogButtonSuccess}" />
                    <Button
                        Click="OnKeepRemote"
                        Content="保留远端版本"
                        Style="{StaticResource DialogButtonPrimary}" />
                    <Button
                        Click="OnMerge"
                        Content="手动合并"
                        Style="{StaticResource DialogButtonAccentDeep}" />
                    <Button
                        Click="OnKeepAllLocal"
                        Content="全部保留本地"
                        Style="{StaticResource DialogButtonMuted}" />
                    <Button
                        Click="OnClose"
                        Content="关闭"
                        Style="{StaticResource DialogButtonNeutral}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <Border
                    Padding="12,8"
                    Background="{DynamicResource Brush.Success}"
                    CornerRadius="6,6,0,0"
                    DockPanel.Dock="Top">
                    <StackPanel>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="本地版本" />
                        <TextBlock
                            x:Name="LocalTimestamp"
                            FontSize="11"
                            Foreground="#c8e6c9"
                            Text="" />
                    </StackPanel>
                </Border>
                <Border
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,6,6"
                    Style="{StaticResource WindowContentCard}">
                    <TextBox x:Name="LocalContentBox" IsReadOnly="True" Style="{StaticResource WindowCodeTextBox}" />
                </Border>
            </DockPanel>

            <DockPanel Grid.Column="2">
                <Border
                    Padding="12,8"
                    Background="{DynamicResource Brush.Accent}"
                    CornerRadius="6,6,0,0"
                    DockPanel.Dock="Top">
                    <StackPanel>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="远端版本" />
                        <TextBlock
                            x:Name="RemoteTimestamp"
                            FontSize="11"
                            Foreground="#e8d5bf"
                            Text="" />
                    </StackPanel>
                </Border>
                <Border
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,6,6"
                    Style="{StaticResource WindowContentCard}">
                    <TextBox x:Name="RemoteContentBox" IsReadOnly="True" Style="{StaticResource WindowCodeTextBox}" />
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
