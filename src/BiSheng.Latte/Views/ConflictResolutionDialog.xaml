<Window
    x:Class="BiSheng.Latte.Views.ConflictResolutionDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="clr-namespace:BiSheng.Latte.Models"
    xmlns:search="clr-namespace:BiSheng.Latte.Controls.Search"
    Title="同步冲突解决"
    Width="1100"
    Height="740"
    MinWidth="880"
    MinHeight="560"
    Background="{DynamicResource Brush.BgCanvas}"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <DataTemplate x:Key="DiffLineTemplate" DataType="{x:Type models:ConflictDiffLine}">
            <Border Padding="6,2" Background="Transparent">
                <Border.Style>
                    <Style TargetType="Border">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Kind}" Value="Deleted">
                                <Setter Property="Background" Value="#33C62828" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding Kind}" Value="Inserted">
                                <Setter Property="Background" Value="#332E7D32" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <TextBlock
                    FontFamily="Consolas, Cascadia Mono, Courier New"
                    FontSize="12.5"
                    Text="{Binding DisplayText}"
                    TextWrapping="NoWrap">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Kind}" Value="Deleted">
                                    <Setter Property="Foreground" Value="#B71C1C" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Kind}" Value="Inserted">
                                    <Setter Property="Foreground" Value="#1B5E20" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource WindowHeaderBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource WindowTitleText}" Text="同步冲突解决" />
                <TextBlock
                    x:Name="ConflictCountText"
                    Margin="0,4,0,0"
                    Style="{StaticResource WindowSubtitleText}"
                    Text="检测到冲突" />
                <TextBlock
                    x:Name="ActionPairText"
                    Margin="0,6,0,0"
                    FontSize="12.5"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Brush.Accent}"
                    Text="" />
                <TextBlock
                    Margin="0,6,0,0"
                    Style="{StaticResource WindowHintText}"
                    Text="请先查看差异，再选择保留本地、保留远端，或手动合并。不会自动合并正文。" />

                <StackPanel Margin="0,12,0,0" Orientation="Horizontal">
                    <RadioButton
                        x:Name="ViewSideBySide"
                        Margin="0,0,16,0"
                        Checked="OnViewModeChanged"
                        Content="对照"
                        GroupName="ConflictView" />
                    <RadioButton
                        x:Name="ViewDiff"
                        Margin="0,0,16,0"
                        Checked="OnViewModeChanged"
                        Content="行级 Diff"
                        GroupName="ConflictView" />
                    <RadioButton
                        x:Name="ViewPreview"
                        Checked="OnViewModeChanged"
                        Content="可读预览"
                        GroupName="ConflictView" />
                </StackPanel>
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource WindowFooterBorder}">
            <DockPanel>
                <StackPanel Margin="-8,0,0,0" DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button
                        x:Name="PrevButton"
                        Click="OnPrev"
                        Content="← 上一个"
                        Style="{StaticResource DialogButtonNeutral}" />
                    <Button
                        x:Name="NextButton"
                        Click="OnNext"
                        Content="下一个 →"
                        Style="{StaticResource DialogButtonNeutral}" />
                </StackPanel>

                <StackPanel Margin="-8,0,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        x:Name="KeepLocalButton"
                        Click="OnKeepLocal"
                        Content="保留本地版本"
                        Style="{StaticResource DialogButtonSuccess}" />
                    <Button
                        x:Name="KeepRemoteButton"
                        Click="OnKeepRemote"
                        Content="保留远端版本"
                        Style="{StaticResource DialogButtonPrimary}" />
                    <Button
                        Click="OnMerge"
                        Content="手动合并"
                        Style="{StaticResource DialogButtonAccentDeep}" />
                    <Button
                        Click="OnKeepAllLocal"
                        Content="全部保留本地"
                        Style="{StaticResource DialogButtonMuted}" />
                    <Button
                        Click="OnKeepAllRemote"
                        Content="全部保留远端"
                        Style="{StaticResource DialogButtonMuted}" />
                    <Button
                        Click="OnClose"
                        Content="关闭"
                        Style="{StaticResource DialogButtonNeutral}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 对照 -->
        <Grid x:Name="SideBySidePanel" Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <Border
                    Padding="12,8"
                    Background="{DynamicResource Brush.Success}"
                    CornerRadius="6,6,0,0"
                    DockPanel.Dock="Top">
                    <StackPanel>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="本地版本" />
                        <TextBlock
                            x:Name="LocalTimestamp"
                            FontSize="11"
                            Foreground="#c8e6c9"
                            Text="" />
                    </StackPanel>
                </Border>
                <Border
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,6,6"
                    Style="{StaticResource WindowContentCard}">
                    <TextBox x:Name="LocalContentBox" IsReadOnly="True" Style="{StaticResource WindowCodeTextBox}" />
                </Border>
            </DockPanel>

            <DockPanel Grid.Column="2">
                <Border
                    Padding="12,8"
                    Background="{DynamicResource Brush.Accent}"
                    CornerRadius="6,6,0,0"
                    DockPanel.Dock="Top">
                    <StackPanel>
                        <TextBlock
                            FontSize="14"
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="远端版本" />
                        <TextBlock
                            x:Name="RemoteTimestamp"
                            FontSize="11"
                            Foreground="#e8d5bf"
                            Text="" />
                    </StackPanel>
                </Border>
                <Border
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,6,6"
                    Style="{StaticResource WindowContentCard}">
                    <TextBox x:Name="RemoteContentBox" IsReadOnly="True" Style="{StaticResource WindowCodeTextBox}" />
                </Border>
            </DockPanel>
        </Grid>

        <!-- Diff -->
        <Border
            x:Name="DiffPanel"
            Margin="16"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="6"
            Style="{StaticResource WindowContentCard}"
            Visibility="Collapsed">
            <DockPanel>
                <Border
                    Padding="12,8"
                    Background="{DynamicResource Brush.SurfaceAlt}"
                    BorderBrush="{DynamicResource Brush.BorderLight}"
                    BorderThickness="0,0,0,1"
                    DockPanel.Dock="Top">
                    <TextBlock
                        FontSize="12"
                        Foreground="{DynamicResource Brush.TextSecondary}"
                        Text="红色 − 仅本地 · 绿色 + 仅远端 · 以本地为基准对比远端" />
                </Border>
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DiffLinesList" ItemTemplate="{StaticResource DiffLineTemplate}" />
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- 可读预览 -->
        <Grid x:Name="PreviewPanel" Margin="16" Visibility="Collapsed">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0">
                <Border
                    Padding="12,8"
                    Background="{DynamicResource Brush.Success}"
                    CornerRadius="6,6,0,0"
                    DockPanel.Dock="Top">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="本地预览" />
                </Border>
                <Border
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,6,6"
                    Style="{StaticResource WindowContentCard}">
                    <search:NoteSearchPreviewControl x:Name="LocalPreview" />
                </Border>
            </DockPanel>

            <DockPanel Grid.Column="2">
                <Border
                    Padding="12,8"
                    Background="{DynamicResource Brush.Accent}"
                    CornerRadius="6,6,0,0"
                    DockPanel.Dock="Top">
                    <TextBlock
                        FontSize="14"
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="远端预览" />
                </Border>
                <Border
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,6,6"
                    Style="{StaticResource WindowContentCard}">
                    <search:NoteSearchPreviewControl x:Name="RemotePreview" />
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
