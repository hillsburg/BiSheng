<Window
    x:Class="BiSheng.Latte.Views.MergeEditWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="手动合并"
    Width="1000"
    Height="680"
    MinWidth="800"
    MinHeight="520"
    Background="{DynamicResource Brush.BgCanvas}"
    WindowStartupLocation="CenterOwner">

    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource WindowHeaderBorder}">
            <StackPanel>
                <TextBlock Style="{StaticResource WindowTitleText}" Text="手动合并" />
                <TextBlock
                    Margin="0,6,0,0"
                    Style="{StaticResource WindowHintText}"
                    Text="上方为只读参考。请在下方「合并结果」中编辑最终正文；可用按钮快速填入本地或远端全文。确认时只使用合并结果区内容。" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource WindowFooterBorder}">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Click="OnFillLocal"
                    Content="填入本地"
                    Style="{StaticResource DialogButtonMuted}" />
                <Button
                    Click="OnFillRemote"
                    Content="填入远端"
                    Style="{StaticResource DialogButtonMuted}" />
                <Button
                    Click="OnConfirm"
                    Content="确认合并"
                    Style="{StaticResource DialogButtonAccentDeep}" />
                <Button
                    Click="OnCancel"
                    Content="取消"
                    Style="{StaticResource DialogButtonNeutral}" />
            </StackPanel>
        </Border>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="160" />
                <RowDefinition Height="8" />
                <RowDefinition Height="1.2*" MinHeight="200" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="8" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <DockPanel Grid.Column="0">
                    <Border
                        Padding="10,6"
                        Background="{DynamicResource Brush.Success}"
                        CornerRadius="6,6,0,0"
                        DockPanel.Dock="Top">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="本地参考（只读）" />
                    </Border>
                    <Border
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,6,6"
                        Style="{StaticResource WindowContentCard}">
                        <TextBox
                            x:Name="LocalRefBox"
                            IsReadOnly="True"
                            Style="{StaticResource WindowCodeTextBox}" />
                    </Border>
                </DockPanel>

                <DockPanel Grid.Column="2">
                    <Border
                        Padding="10,6"
                        Background="{DynamicResource Brush.Accent}"
                        CornerRadius="6,6,0,0"
                        DockPanel.Dock="Top">
                        <TextBlock
                            FontWeight="SemiBold"
                            Foreground="White"
                            Text="远端参考（只读）" />
                    </Border>
                    <Border
                        BorderBrush="{DynamicResource Brush.Border}"
                        BorderThickness="1,0,1,1"
                        CornerRadius="0,0,6,6"
                        Style="{StaticResource WindowContentCard}">
                        <TextBox
                            x:Name="RemoteRefBox"
                            IsReadOnly="True"
                            Style="{StaticResource WindowCodeTextBox}" />
                    </Border>
                </DockPanel>
            </Grid>

            <DockPanel Grid.Row="2">
                <Border
                    Padding="10,6"
                    Background="{DynamicResource Brush.AccentHover}"
                    CornerRadius="6,6,0,0"
                    DockPanel.Dock="Top">
                    <TextBlock
                        FontWeight="SemiBold"
                        Foreground="White"
                        Text="合并结果（可编辑 · 确认时以此为准）" />
                </Border>
                <Border
                    BorderBrush="{DynamicResource Brush.Border}"
                    BorderThickness="1,0,1,1"
                    CornerRadius="0,0,6,6"
                    Style="{StaticResource WindowContentCard}">
                    <TextBox
                        x:Name="ResultBox"
                        AcceptsReturn="True"
                        AcceptsTab="True"
                        Style="{StaticResource WindowCodeTextBox}" />
                </Border>
            </DockPanel>
        </Grid>
    </DockPanel>
</Window>
