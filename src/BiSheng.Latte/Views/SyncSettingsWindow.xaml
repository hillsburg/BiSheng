<Window
    x:Class="BiSheng.Latte.Views.SyncSettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="BiSheng Latte - 同步与安全"
    Width="520"
    Height="760"
    Background="{DynamicResource Brush.BgCanvas}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
            <Setter Property="Background" Value="{DynamicResource Brush.BgCanvas}" />
            <Setter Property="BorderBrush" Value="{DynamicResource Brush.Border}" />
            <Setter Property="CaretBrush" Value="{DynamicResource Brush.Accent}" />
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource Brush.Accent}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontFamily" Value="{StaticResource UIFont}" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.Text}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>

    <Border Padding="24">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Margin="0,0,0,12" Style="{StaticResource WindowInfoCard}">
                <StackPanel>
                    <TextBlock
                        Margin="0,0,0,4"
                        FontSize="12"
                        Foreground="{DynamicResource Brush.TextMuted}"
                        Text="当前连接状态" />
                    <TextBlock
                        x:Name="ConnectionStatusText"
                        FontSize="13"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <TabControl x:Name="MainTabControl" Grid.Row="1" Margin="0,0,0,16">
                <TabItem Header="连接">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,12,8,0">
                            <TextBlock
                                Margin="0,0,0,12"
                                FontSize="13"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="配置服务器凭据；关闭「启用同步」可暂停所有同步，开启后可手动同步或配合下方自动同步选项。"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="服务器地址" />
                            <TextBox
                                x:Name="ServerUrlBox"
                                Margin="0,0,0,4"
                                Padding="8,6"
                                BorderThickness="1"
                                FontSize="14"
                                TextChanged="OnConnectionFieldChanged"
                                Text="" />
                            <TextBlock
                                Margin="0,0,0,16"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="留空地址或 API Key 将使用纯本地模式，数据不会同步到服务器"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="API Key" />
                            <PasswordBox
                                x:Name="ApiKeyBox"
                                Margin="0,0,0,4"
                                Padding="8,6"
                                BorderThickness="1"
                                FontFamily="Consolas, monospace"
                                FontSize="13"
                                PasswordChanged="OnApiKeyPasswordChanged" />
                            <TextBlock
                                Margin="0,0,0,16"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="从管理面板（浏览器访问 /admin/keys）获取；输入时以掩码显示，本地以 Windows DPAPI 加密保存"
                                TextWrapping="Wrap" />

                            <CheckBox
                                x:Name="SyncEnabledSwitch"
                                Checked="OnSyncEnabledChanged"
                                Content="启用同步"
                                Unchecked="OnSyncEnabledChanged"
                                Visibility="Collapsed" />
                            <TextBlock
                                Margin="0,0,0,12"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="关闭后暂停 Push / Pull 与手动同步；开启后可使用工具栏「手动同步」。"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,0,0,12"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="服务器地址与 API Key 修改后需点击保存；启用同步开关立即生效。"
                                TextWrapping="Wrap" />

                            <Button
                                x:Name="TestConnectionButton"
                                Margin="0"
                                HorizontalAlignment="Left"
                                Click="OnTestConnection"
                                Content="测试连接"
                                Style="{StaticResource DialogButtonPrimary}" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="同步">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,12,8,0">
                            <TextBlock
                                Margin="0,0,0,12"
                                FontSize="13"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="单人多端：本地编辑优先落盘，按节奏 Push 到云端；其他设备的变更仍通过 SignalR 实时 Pull。"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="笔记 Push 周期（秒）" />
                            <TextBox
                                x:Name="PeriodicPushBox"
                                Width="120"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,4"
                                Padding="8,6"
                                BorderThickness="1"
                                FontSize="14" />
                            <TextBlock
                                Margin="0,0,0,16"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="有待推送变更时，按此间隔上传到服务器（5–600 秒）" />

                            <CheckBox x:Name="FlushOnExitBox" Content="关闭应用前推送未同步变更" />
                            <CheckBox x:Name="SyncOnActivatedBox" Content="窗口重新激活时同步" />
                            <CheckBox
                                x:Name="SyncOnNetworkRecoverBox"
                                Margin="0,0,0,16"
                                Content="网络 / SignalR 恢复时同步" />

                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="图片上传周期（秒）" />
                            <TextBox
                                x:Name="ImageUploadBox"
                                Width="120"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,4"
                                Padding="8,6"
                                BorderThickness="1"
                                FontSize="14" />
                            <TextBlock
                                Margin="0,0,0,16"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="扫描未上传图片并上传（5–600 秒）" />

                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="图片拉取周期（秒）" />
                            <TextBox
                                x:Name="ImagePullBox"
                                Width="120"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,4"
                                Padding="8,6"
                                BorderThickness="1"
                                FontSize="14" />
                            <TextBlock
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="从服务器增量下载新图片（10–3600 秒）" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="数据安全">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="8,12,8,0">
                            <TextBlock
                                Margin="0,0,0,12"
                                FontSize="13"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="自动备份、编辑日志与回收站；保守模式会缩短 Push 周期并使本地历史采样更密。"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="安全档位" />
                            <ComboBox
                                x:Name="ProfileCombo"
                                Width="200"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16"
                                Padding="8,6" />

                            <CheckBox x:Name="EnableAutoBackupBox" Content="启用 local.db 自动备份" />
                            <CheckBox x:Name="BackupOnExitBox" Content="关闭应用时备份" />

                            <TextBlock
                                Margin="0,12,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="保留备份份数" />
                            <TextBox
                                x:Name="BackupRetentionBox"
                                Width="120"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,4"
                                Padding="8,6"
                                BorderThickness="1"
                                FontSize="14" />
                            <TextBlock
                                Margin="0,0,0,16"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="超出后删除最旧备份（3–90 份）" />

                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="定时备份间隔（小时）" />
                            <TextBox
                                x:Name="BackupIntervalBox"
                                Width="120"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,4"
                                Padding="8,6"
                                BorderThickness="1"
                                FontSize="14" />
                            <TextBlock
                                Margin="0,0,0,8"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                Text="0 = 仅退出时备份；1–168 = 启动/定时检查（默认 24）"
                                TextWrapping="Wrap" />

                            <TextBlock
                                Margin="0,8,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="备份位置" />
                            <CheckBox
                                x:Name="BackupUseDefaultBox"
                                Checked="OnBackupLocationModeChanged"
                                Content="使用默认位置"
                                Unchecked="OnBackupLocationModeChanged" />
                            <TextBlock
                                x:Name="BackupDefaultPathText"
                                Margin="24,0,0,8"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                TextWrapping="Wrap" />
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox
                                    x:Name="BackupCustomPathBox"
                                    IsReadOnly="True"
                                    Padding="8,6"
                                    BorderThickness="1"
                                    FontSize="13" />
                                <Button
                                    x:Name="BackupBrowseButton"
                                    Grid.Column="1"
                                    Margin="8,0,0,0"
                                    Background="{DynamicResource Brush.SurfaceAlt}"
                                    Click="OnBrowseBackupFolder"
                                    Content="浏览…"
                                    Foreground="{DynamicResource Brush.Text}" />
                            </Grid>
                            <Button
                                x:Name="ManageBackupsButton"
                                Margin="0,0,0,8"
                                HorizontalAlignment="Left"
                                Background="{DynamicResource Brush.SurfaceAlt}"
                                Click="OnManageBackups"
                                Content="管理备份…"
                                Foreground="{DynamicResource Brush.Text}" />
                            <TextBlock
                                x:Name="BackupPathHint"
                                Margin="0,0,0,16"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                TextWrapping="Wrap" />

                            <CheckBox x:Name="EnableEditJournalBox" Content="记录只追加编辑日志（Push 成功后打标）" />

                            <TextBlock
                                Margin="0,12,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="编辑日志保留（天）" />
                            <TextBox
                                x:Name="EditJournalRetentionBox"
                                Width="120"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16"
                                Padding="8,6"
                                BorderThickness="1"
                                FontSize="14" />

                            <TextBlock
                                Margin="0,0,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="回收站保留（天）" />
                            <TextBox
                                x:Name="TrashRetentionBox"
                                Width="120"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,16"
                                Padding="8,6"
                                BorderThickness="1"
                                FontSize="14" />

                            <CheckBox x:Name="EnableExportReminderBox" Content="提醒定期导出全库（BiSheng Archive）" />

                            <TextBlock
                                Margin="0,8,0,4"
                                FontWeight="SemiBold"
                                Foreground="{DynamicResource Brush.TextSecondary}"
                                Text="导出提醒间隔（天）" />
                            <TextBox
                                x:Name="RemindExportBox"
                                Width="120"
                                HorizontalAlignment="Left"
                                Margin="0,0,0,4"
                                Padding="8,6"
                                BorderThickness="1"
                                FontSize="14" />
                            <TextBlock
                                x:Name="LastExportHint"
                                FontSize="12"
                                Foreground="{DynamicResource Brush.TextMuted}"
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>

            <StackPanel Grid.Row="2">
                <TextBlock
                    x:Name="StatusText"
                    Margin="0,0,0,12"
                    FontSize="13"
                    Foreground="{DynamicResource Brush.TextMuted}"
                    Text=""
                    TextWrapping="Wrap" />
                <StackPanel Margin="-8,0,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        Click="OnSave"
                        Content="保存"
                        IsDefault="True"
                        Style="{StaticResource DialogButtonPrimary}" />
                    <Button
                        Click="OnCancel"
                        Content="取消"
                        IsCancel="True"
                        Style="{StaticResource DialogButtonNeutral}" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</Window>
