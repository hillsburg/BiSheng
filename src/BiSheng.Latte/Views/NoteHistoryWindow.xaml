<Window
    x:Class="BiSheng.Latte.Views.NoteHistoryWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="历史版本"
    Width="960"
    Height="680"
    MinWidth="720"
    MinHeight="480"
    Background="{DynamicResource Brush.BgCanvas}"
    WindowStartupLocation="CenterOwner">

    <DockPanel>
        <Border DockPanel.Dock="Top" Style="{StaticResource WindowHeaderBorder}">
            <StackPanel>
                <TextBlock x:Name="TitleText" Style="{StaticResource WindowTitleText}" Text="历史版本" />
                <TextBlock
                    x:Name="SubtitleText"
                    Style="{StaticResource WindowHintText}"
                    Margin="0,6,0,0"
                    Text="每篇笔记最多保留 100 个版本；删除笔记后历史仍保留，可在此手动清理。" />
            </StackPanel>
        </Border>

        <Border DockPanel.Dock="Bottom" Style="{StaticResource WindowFooterBorder}">
            <DockPanel>
                <StackPanel Margin="-8,0,0,0" DockPanel.Dock="Left" Orientation="Horizontal">
                    <Button
                        x:Name="DeleteRevisionButton"
                        Click="OnDeleteRevision"
                        Content="删除选中版本"
                        Style="{StaticResource DialogButtonNeutral}" />
                    <Button
                        x:Name="DeleteAllButton"
                        Click="OnDeleteAll"
                        Content="清空全部历史"
                        Style="{StaticResource DialogButtonDanger}" />
                </StackPanel>
                <StackPanel Margin="-8,0,0,0" HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button
                        x:Name="SaveCurrentButton"
                        Click="OnSaveCurrent"
                        Content="保存当前版本"
                        Style="{StaticResource DialogButtonNeutral}" />
                    <Button
                        Content="关闭"
                        IsCancel="True"
                        Style="{StaticResource DialogButtonNeutral}" />
                    <Button
                        x:Name="RestoreButton"
                        Click="OnRestore"
                        Content="恢复此版本"
                        IsDefault="True"
                        Style="{StaticResource DialogButtonPrimary}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource WindowContentCard}">
                <Grid>
                    <ListBox
                        x:Name="RevisionList"
                        Background="Transparent"
                        BorderThickness="0"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        SelectionChanged="OnRevisionSelected">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4,6">
                                    <TextBlock
                                        FontSize="13"
                                        FontWeight="SemiBold"
                                        Text="{Binding Label}" />
                                    <TextBlock
                                        Margin="0,2,0,0"
                                        FontSize="11"
                                        Foreground="{DynamicResource Brush.TextMuted}"
                                        Text="{Binding SubLabel}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                    <TextBlock
                        x:Name="EmptyStateText"
                        Style="{StaticResource QuietEmptyStateText}"
                        Text="暂无历史版本"
                        Visibility="Collapsed" />
                </Grid>
            </Border>

            <Border Grid.Column="2" Padding="12" Style="{StaticResource WindowContentCard}">
                <Grid>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <TextBox
                            x:Name="PreviewBox"
                            Background="Transparent"
                            BorderThickness="0"
                            FontFamily="{StaticResource CodeFont}"
                            FontSize="13"
                            Foreground="{DynamicResource Brush.Text}"
                            IsReadOnly="True"
                            AcceptsReturn="True"
                            TextWrapping="Wrap" />
                    </ScrollViewer>
                    <TextBlock
                        x:Name="PreviewEmptyText"
                        Style="{StaticResource QuietEmptyStateText}"
                        Text="选中版本后在此预览"
                        Visibility="Collapsed" />
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
