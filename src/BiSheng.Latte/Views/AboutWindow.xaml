<Window
    x:Class="BiSheng.Latte.Views.AboutWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="关于 BiSheng Latte"
    Width="460"
    Height="340"
    Background="{DynamicResource Brush.BgCanvas}"
    ResizeMode="NoResize"
    WindowStartupLocation="CenterOwner">

    <DockPanel Style="{StaticResource WindowPaddedRoot}">
        <StackPanel Margin="-8,0,0,0" DockPanel.Dock="Bottom" Orientation="Horizontal">
            <Button
                x:Name="CheckUpdateButton"
                Click="OnCheckUpdateClick"
                Content="检查更新"
                Style="{StaticResource DialogButtonPrimary}" />
            <Button
                x:Name="ApplyUpdateButton"
                Click="OnApplyUpdateClick"
                Content="立即更新"
                IsEnabled="False"
                Style="{StaticResource DialogButtonPrimary}"
                Visibility="Collapsed" />
            <Button
                Click="OnCloseClick"
                Content="关闭"
                Style="{StaticResource DialogButtonSecondary}" />
        </StackPanel>

        <StackPanel>
            <TextBlock
                Style="{StaticResource WindowTitleText}"
                Text="BiSheng Latte" />
            <TextBlock
                x:Name="VersionText"
                Margin="0,8,0,0"
                Style="{StaticResource WindowSubtitleText}"
                Text="版本" />
            <TextBlock
                Margin="0,4,0,0"
                FontSize="12"
                Foreground="{DynamicResource Brush.TextMuted}"
                Text="更新源：GitHub Releases（hillsburg/BiSheng）" />

            <Border Margin="0,16,0,0" Style="{StaticResource WindowInfoCard}">
                <StackPanel>
                    <TextBlock
                        x:Name="StatusText"
                        FontSize="13"
                        Foreground="{DynamicResource Brush.Text}"
                        TextWrapping="Wrap"
                        Text="点击「检查更新」查询是否有新版本。默认不会自动下载安装。" />
                    <ProgressBar
                        x:Name="DownloadProgress"
                        Height="6"
                        Margin="0,12,0,0"
                        Maximum="100"
                        Visibility="Collapsed" />
                </StackPanel>
            </Border>
        </StackPanel>
    </DockPanel>
</Window>
