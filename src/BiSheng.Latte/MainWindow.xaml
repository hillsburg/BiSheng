<Window
    x:Class="BiSheng.Latte.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:BiSheng.Latte.Converters"
    xmlns:ctrl="clr-namespace:BiSheng.Latte.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:BiSheng.Latte"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:md="clr-namespace:BiSheng.Editor.Controls.MarkdownEditor;assembly=BiSheng.Editor"
    xmlns:nav="clr-namespace:BiSheng.Latte.Controls.Navigation"
    xmlns:vm="clr-namespace:BiSheng.Latte.ViewModels"
    Title="BiSheng Latte"
    Width="1280"
    Height="768"
    Background="{DynamicResource Brush.BgCanvas}"
    BorderThickness="0"
    PreviewMouseLeftButtonDown="OnWindowPreviewMouseLeftButtonDown"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <Window.InputBindings>
        <KeyBinding
            Key="F"
            Modifiers="Control+Shift"
            Command="{Binding OpenNoteSearchCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <conv:DoubleToGridLengthConverter x:Key="DoubleToGridLength" />
        <conv:HexColorToBrushConverter x:Key="HexColorToBrush" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:ResourceKeyToBrushConverter x:Key="ResourceKeyToBrush" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <DockPanel>
            <!--  顶部工具栏（仅顶部模式）  -->
            <Border
                x:Name="ToolbarBorder"
                Padding="10,6"
                Background="{DynamicResource Brush.ToolbarBg}"
                DockPanel.Dock="Top"
                MouseLeftButtonDown="OnToolbarDrag"
                Visibility="{Binding IsToolbarTop, Converter={StaticResource BoolToVis}}">
                <ctrl:AppToolbar />
            </Border>

            <!--  底部状态栏：与工具栏徽章共用 ConnectionDisplay；可隐藏，连接态仍由工具栏兜底  -->
            <Border
                x:Name="StatusBarBorder"
                Padding="14,5"
                Background="{DynamicResource Brush.SurfaceAlt}"
                BorderBrush="{DynamicResource Brush.BorderLight}"
                BorderThickness="0,1,0,0"
                DockPanel.Dock="Bottom">
                <Button
                    Padding="0"
                    HorizontalAlignment="Left"
                    HorizontalContentAlignment="Left"
                    Background="Transparent"
                    BorderThickness="0"
                    Command="{Binding OpenConnectionStatusCommand}"
                    Cursor="Hand"
                    ToolTip="{Binding ConnectionDisplay.DetailText}">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent">
                                <ContentPresenter />
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock
                            VerticalAlignment="Center"
                            FontFamily="Segoe MDL2 Assets"
                            FontSize="12"
                            Foreground="{Binding ConnectionDisplay.BrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                            Text="{Binding ConnectionDisplay.IconGlyph}" />
                        <TextBlock
                            Margin="8,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Foreground="{Binding ConnectionDisplay.BrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                            Text="{Binding ConnectionDisplay.StatusBarText}" />
                    </StackPanel>
                </Button>
            </Border>

            <!--  主三栏区域  -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <!--  0: 左侧工具栏（导航左侧模式）  -->
                    <ColumnDefinition Width="{Binding ToolbarSidebarColumnWidth, Converter={StaticResource DoubleToGridLength}}" />
                    <!--  1: 导航（归纳 / 并列）  -->
                    <ColumnDefinition Width="{Binding NavColumnWidth, Mode=TwoWay, Converter={StaticResource DoubleToGridLength}}" MaxWidth="900" />
                    <ColumnDefinition Width="Auto" />
                    <!--  3: 编辑器  -->
                    <ColumnDefinition Width="*" MinWidth="400" />
                    <ColumnDefinition Width="Auto" />
                    <!--  5: 大纲  -->
                    <ColumnDefinition Width="{Binding OutlineColumnWidth, Mode=TwoWay, Converter={StaticResource DoubleToGridLength}}" />
                </Grid.ColumnDefinitions>

                <!--  导航左侧工具栏  -->
                <Border
                    x:Name="SidebarToolbarBorder"
                    Grid.Column="0"
                    Padding="3,8"
                    Background="{DynamicResource Brush.ToolbarBg}"
                    BorderBrush="{DynamicResource Brush.BorderLight}"
                    BorderThickness="0,0,1,0"
                    MouseLeftButtonDown="OnToolbarDrag"
                    Visibility="{Binding IsToolbarNavLeft, Converter={StaticResource BoolToVis}}">
                    <ctrl:AppToolbar />
                </Border>

                <!--  归纳模式导航  -->
                <nav:TreeNavigationPanel Grid.Column="1" Visibility="{Binding IsMergedNavVisible, Converter={StaticResource BoolToVis}}" />

                <!--  并列模式导航（文件夹 + 笔记）  -->
                <nav:SideBySideNavigationPanel Grid.Column="1" Visibility="{Binding IsSideBySideNavVisible, Converter={StaticResource BoolToVis}}" />

                <!--  导航与编辑器之间的分割线（两种模式共用）  -->
                <GridSplitter
                    Grid.Column="2"
                    Width="3"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource Brush.BorderLight}"
                    ResizeBehavior="PreviousAndNext"
                    Visibility="{Binding IsFolderPanelVisible, Converter={StaticResource BoolToVis}}" />

                <!--  Markdown 编辑器  -->
                <Border Grid.Column="3" Background="{DynamicResource Brush.BgCanvas}">
                    <md:MarkdownEditorControl
                        x:Name="NoteEditor"
                        EditorFontFamily="{DynamicResource ContentFont}"
                        EditorFontSize="15"
                        LineSpacing="1.5" />
                </Border>

                <!--  大纲分割线  -->
                <GridSplitter
                    Grid.Column="4"
                    Width="3"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Stretch"
                    Background="{DynamicResource Brush.BorderLight}"
                    ResizeBehavior="PreviousAndNext"
                    Visibility="{Binding IsOutlinePanelVisible, Converter={StaticResource BoolToVis}}" />

                <!--  笔记大纲  -->
                <Border
                    Grid.Column="5"
                    Background="{DynamicResource Brush.Surface}"
                    BorderBrush="{DynamicResource Brush.BorderLight}"
                    BorderThickness="1,0,0,0"
                    Visibility="{Binding IsOutlinePanelVisible, Converter={StaticResource BoolToVis}}">
                    <DockPanel>
                        <!--  区域标题  -->
                        <Border Padding="16,10,16,6" DockPanel.Dock="Top">
                            <StackPanel Orientation="Horizontal">
                                <Border
                                    Width="3"
                                    Height="14"
                                    Margin="0,0,8,0"
                                    VerticalAlignment="Center"
                                    Background="{DynamicResource Brush.Accent}"
                                    CornerRadius="1.5" />
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource Brush.TextSecondary}"
                                    Text="大纲" />
                            </StackPanel>
                        </Border>
                        <TreeView
                            x:Name="OutlineTree"
                            Padding="8,4"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemsSource="{Binding Outline.Items}"
                            MouseDoubleClick="OnOutlineTreeDoubleClick"
                            VirtualizingPanel.IsVirtualizing="True"
                            VirtualizingPanel.VirtualizationMode="Recycling">
                            <TreeView.ItemContainerStyle>
                                <Style BasedOn="{StaticResource NavTreeViewItemStyle}" TargetType="TreeViewItem">
                                    <Setter Property="Cursor" Value="Hand" />
                                    <Setter Property="FontSize" Value="13" />
                                </Style>
                            </TreeView.ItemContainerStyle>
                            <TreeView.ItemTemplate>
                                <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                    <TextBlock
                                        FontWeight="{Binding FontWeight}"
                                        Foreground="{DynamicResource Brush.Text}"
                                        Text="{Binding Title}"
                                        TextTrimming="CharacterEllipsis" />
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </DockPanel>
                </Border>
            </Grid>
        </DockPanel>

        <!--  启动 / 关闭同步遮罩  -->
        <Border
            Panel.ZIndex="100"
            Background="#CC2C2520"
            IsHitTestVisible="{Binding IsLoadingOverlayVisible}"
            Visibility="{Binding IsLoadingOverlayVisible, Converter={StaticResource BoolToVis}}">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource Brush.Surface}"
                    Text="{Binding LoadingOverlayText}" />
                <ProgressBar
                    Width="220"
                    Height="4"
                    Margin="0,18,0,0"
                    Background="{DynamicResource Brush.BorderLight}"
                    BorderThickness="0"
                    Foreground="{DynamicResource Brush.Accent}"
                    IsIndeterminate="True" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
