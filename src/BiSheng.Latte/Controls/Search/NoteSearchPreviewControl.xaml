<UserControl
    x:Class="BiSheng.Latte.Controls.Search.NoteSearchPreviewControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit">

    <Border
        Padding="8"
        Background="{DynamicResource Brush.SurfaceAlt}"
        BorderBrush="{DynamicResource Brush.BorderLight}"
        BorderThickness="1"
        CornerRadius="6">
        <avalonEdit:TextEditor x:Name="PreviewHost" />
    </Border>
</UserControl>
