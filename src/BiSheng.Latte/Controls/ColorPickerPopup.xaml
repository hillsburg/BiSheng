<Window
    x:Class="BiSheng.Latte.Controls.ColorPickerPopup"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="选择颜色"
    Width="320"
    MinHeight="380"
    SizeToContent="Height"
    WindowStartupLocation="CenterOwner"
    ResizeMode="NoResize"
    WindowStyle="ToolWindow"
    ShowInTaskbar="False"
    Background="{DynamicResource Brush.BgCanvas}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--
          饱和度(S) × 明度(V) 方块：当前色相下所见即所得。
          左上白、右上纯色、底部黑。
        -->
        <Border
            Grid.Row="0"
            HorizontalAlignment="Center"
            Margin="0,0,0,10"
            BorderBrush="{DynamicResource Brush.Border}"
            BorderThickness="1"
            CornerRadius="4">
            <Canvas
                x:Name="SvCanvas"
                Width="240"
                Height="180"
                Background="Transparent"
                ClipToBounds="True"
                Cursor="Cross"
                MouseLeftButtonDown="OnSvMouseDown"
                MouseLeftButtonUp="OnSvMouseUp"
                MouseMove="OnSvMouseMove">
                <Rectangle
                    x:Name="SvHueBase"
                    Width="240"
                    Height="180"
                    IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop x:Name="SvWhiteStop" Offset="0" Color="White" />
                            <GradientStop x:Name="SvHueStop" Offset="1" Color="#FF0000" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Rectangle
                    Width="240"
                    Height="180"
                    IsHitTestVisible="False">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#00000000" />
                            <GradientStop Offset="1" Color="#FF000000" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>
                <Ellipse
                    x:Name="PickerCursor"
                    Width="12"
                    Height="12"
                    Fill="Transparent"
                    IsHitTestVisible="False"
                    Stroke="White"
                    StrokeThickness="2" />
            </Canvas>
        </Border>

        <!-- 色相条：拖动改变 H，方块同步换底色 -->
        <DockPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock
                Margin="0,0,8,0"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{DynamicResource Brush.TextSecondary}"
                Text="色相" />
            <Border
                Height="18"
                VerticalAlignment="Center"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="3"
                ClipToBounds="True">
                <Grid>
                    <Border IsHitTestVisible="False">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0" Color="#FF0000" />
                                <GradientStop Offset="0.167" Color="#FFFF00" />
                                <GradientStop Offset="0.333" Color="#00FF00" />
                                <GradientStop Offset="0.5" Color="#00FFFF" />
                                <GradientStop Offset="0.667" Color="#0000FF" />
                                <GradientStop Offset="0.833" Color="#FF00FF" />
                                <GradientStop Offset="1" Color="#FF0000" />
                            </LinearGradientBrush>
                        </Border.Background>
                    </Border>
                    <Slider
                        x:Name="HueSlider"
                        VerticalAlignment="Center"
                        Maximum="360"
                        Minimum="0"
                        Opacity="0.85"
                        TickFrequency="1"
                        ValueChanged="OnHueChanged" />
                </Grid>
            </Border>
        </DockPanel>

        <!-- 预览 + HEX：与方块取样颜色一致 -->
        <DockPanel Grid.Row="2" Margin="0,0,0,16">
            <Border
                Width="36"
                Height="36"
                Margin="0,0,10,0"
                BorderBrush="{DynamicResource Brush.Border}"
                BorderThickness="1"
                CornerRadius="4"
                DockPanel.Dock="Left"
                SnapsToDevicePixels="True">
                <Rectangle x:Name="PreviewFill" RadiusX="3" RadiusY="3" />
            </Border>
            <TextBlock
                Margin="0,0,6,0"
                VerticalAlignment="Center"
                DockPanel.Dock="Left"
                FontSize="12"
                Foreground="{DynamicResource Brush.TextSecondary}"
                Text="HEX" />
            <TextBox
                x:Name="HexInput"
                Padding="6,4"
                VerticalContentAlignment="Center"
                FontFamily="Consolas, monospace"
                FontSize="14"
                TextChanged="OnHexChanged" />
        </DockPanel>

        <StackPanel
            Grid.Row="3"
            Margin="0,0,0,4"
            HorizontalAlignment="Right"
            Orientation="Horizontal">
            <Button
                Click="OnCancel"
                Content="取消"
                Style="{StaticResource DialogButtonNeutral}" />
            <Button
                Click="OnConfirm"
                Content="确定"
                Style="{StaticResource DialogButtonPrimary}" />
        </StackPanel>
    </Grid>
</Window>
