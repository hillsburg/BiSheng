<UserControl
    x:Class="BiSheng.Latte.Controls.Navigation.SideBySideNavigationPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:BiSheng.Latte.Converters"
    xmlns:local="clr-namespace:BiSheng.Latte"
    xmlns:vm="clr-namespace:BiSheng.Latte.ViewModels">

    <UserControl.Resources>
        <conv:DoubleToGridLengthConverter x:Key="DoubleToGridLength" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="FolderTreeItemStyle" TargetType="TreeViewItem" BasedOn="{StaticResource NavTreeViewItemStyle}">
            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
        </Style>

        <Style x:Key="NoteListItemStyle" TargetType="ListBoxItem" BasedOn="{StaticResource NavListBoxItemStyle}" />

        <HierarchicalDataTemplate DataType="{x:Type vm:FolderNode}" ItemsSource="{Binding Children}">
            <StackPanel Margin="2,2" Orientation="Horizontal">
                <TextBlock Margin="0,0,8,0" VerticalAlignment="Center"
                    FontFamily="Segoe MDL2 Assets" FontSize="14"
                    Foreground="{DynamicResource Brush.Accent}" Text="&#xE8B7;" />
                <TextBlock VerticalAlignment="Center" FontSize="13" Foreground="{DynamicResource Brush.Text}"
                    Text="{Binding Name}">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
                <TextBlock Margin="4,0,0,0" FontFamily="Segoe MDL2 Assets" FontSize="11"
                    Foreground="{DynamicResource Brush.Accent}" Text="&#xE718;"
                    Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}" />
                <TextBlock Margin="2,0,0,0" FontFamily="Segoe MDL2 Assets" FontSize="11"
                    Foreground="{DynamicResource Brush.Accent}" Text="&#xE735;"
                    Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}" />
                <TextBox Width="140" Padding="2,1" VerticalContentAlignment="Center"
                    local:TextBoxAutoSelect.IsEnabled="True" FontSize="13"
                    PreviewKeyDown="OnRenameTextBoxPreviewKeyDown"
                    LostKeyboardFocus="OnRenameTextBoxLostFocus"
                    Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}">
                    <TextBox.Style>
                        <Style TargetType="TextBox">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBox.Style>
                </TextBox>
            </StackPanel>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MaxWidth="400"
                Width="{Binding FolderColumnWidth, Mode=TwoWay, Converter={StaticResource DoubleToGridLength}}" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition MinWidth="180" MaxWidth="400"
                Width="{Binding NoteColumnWidth, Mode=TwoWay, Converter={StaticResource DoubleToGridLength}}" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.BorderLight}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border Padding="16,10,16,6" DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="3" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                            Background="{DynamicResource Brush.Accent}" CornerRadius="1.5" />
                        <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextSecondary}" Text="文件夹" />
                    </StackPanel>
                </Border>
                <Border Padding="12,0,12,8" DockPanel.Dock="Top">
                    <DockPanel>
                        <Button
                            DockPanel.Dock="Right"
                            Margin="8,0,0,0"
                            Command="{Binding RevealActiveNoteInNavigationCommand}"
                            Style="{StaticResource NavLocateButton}">
                            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="14" Text="&#xE1C4;" />
                        </Button>
                        <TextBox Padding="10,6" FontSize="13"
                            Background="{DynamicResource Brush.SurfaceAlt}"
                            BorderBrush="{DynamicResource Brush.BorderLight}"
                            Style="{StaticResource WatermarkTextBox}"
                            Tag="搜索文件夹或笔记…"
                            Text="{Binding Navigation.SearchInput, UpdateSourceTrigger=PropertyChanged}">
                            <TextBox.InputBindings>
                                <KeyBinding Key="Return" Command="{Binding Navigation.ApplySearchCommand}" />
                            </TextBox.InputBindings>
                        </TextBox>
                    </DockPanel>
                </Border>
                <Expander Padding="8,0,8,4" DockPanel.Dock="Top" Header="收藏"
                    IsExpanded="{Binding Navigation.IsFavoritesExpanded, Mode=TwoWay}"
                    Visibility="{Binding Navigation.HasFavorites, Converter={StaticResource BoolToVis}}">
                    <ListBox x:Name="FavoritesList" Background="Transparent" BorderThickness="0"
                        ItemContainerStyle="{StaticResource NoteListItemStyle}"
                        ItemsSource="{Binding Navigation.FavoriteItems}"
                        ContextMenuOpening="FavoritesList_ContextMenuOpening"
                        PreviewMouseLeftButtonDown="FavoritesList_PreviewMouseLeftButtonDown">
                        <ListBox.Resources>
                            <DataTemplate DataType="{x:Type vm:FolderNode}">
                                <TextBlock FontSize="13" Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                            <DataTemplate DataType="{x:Type vm:NoteItemViewModel}">
                                <TextBlock FontSize="13" Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                            </DataTemplate>
                        </ListBox.Resources>
                    </ListBox>
                </Expander>
                <TreeView x:Name="FolderTree" Padding="6,0" Background="Transparent" BorderThickness="0"
                    ContextMenuOpening="FolderTree_ContextMenuOpening"
                    ItemContainerStyle="{StaticResource FolderTreeItemStyle}"
                    ItemsSource="{Binding FolderTree.RootNodes}"
                    PreviewKeyDown="FolderTree_PreviewKeyDown"
                    PreviewMouseLeftButtonDown="FolderTree_PreviewMouseLeftButtonDown"
                    SelectedItemChanged="FolderTree_SelectedItemChanged" />
            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1" Width="3" HorizontalAlignment="Center"
            VerticalAlignment="Stretch" Background="{DynamicResource Brush.BorderLight}"
            ResizeBehavior="PreviousAndNext" />

        <Border Grid.Column="2" Background="{DynamicResource Brush.Surface}"
            BorderBrush="{DynamicResource Brush.BorderLight}" BorderThickness="0,0,1,0">
            <DockPanel>
                <Border Padding="16,10,16,6" DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal">
                        <Border Width="3" Height="14" Margin="0,0,8,0" VerticalAlignment="Center"
                            Background="{DynamicResource Brush.Accent}" CornerRadius="1.5" />
                        <TextBlock VerticalAlignment="Center" FontSize="13" FontWeight="SemiBold"
                            Foreground="{DynamicResource Brush.TextSecondary}" Text="笔记" />
                    </StackPanel>
                </Border>
                <ListBox x:Name="NoteList" Padding="6,0"
                    ContextMenuOpening="NoteList_ContextMenuOpening"
                    ItemContainerStyle="{StaticResource NoteListItemStyle}"
                    ItemsSource="{Binding NoteList.Notes}"
                    MouseDoubleClick="NoteList_MouseDoubleClick"
                    PreviewKeyDown="NoteList_PreviewKeyDown"
                    PreviewMouseLeftButtonDown="NoteList_PreviewMouseLeftButtonDown"
                    SelectedItem="{Binding NoteList.SelectedNote}">
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:NoteItemViewModel}">
                            <Grid>
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock FontSize="13" Foreground="{DynamicResource Brush.Text}"
                                        Text="{Binding Title}" TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Visibility" Value="Visible" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Margin="6,0,0,0" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                        Foreground="{DynamicResource Brush.Accent}" Text="&#xE718;"
                                        Visibility="{Binding IsPinned, Converter={StaticResource BoolToVis}}" />
                                    <TextBlock Margin="2,0,0,0" FontFamily="Segoe MDL2 Assets" FontSize="11"
                                        Foreground="{DynamicResource Brush.Accent}" Text="&#xE735;"
                                        Visibility="{Binding IsFavorite, Converter={StaticResource BoolToVis}}" />
                                </StackPanel>
                                <TextBox Padding="2,1" VerticalContentAlignment="Center"
                                    local:TextBoxAutoSelect.IsEnabled="True" FontSize="13"
                                    PreviewKeyDown="OnRenameTextBoxPreviewKeyDown"
                                    LostKeyboardFocus="OnRenameTextBoxLostFocus"
                                    Text="{Binding RenameText, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.Style>
                                        <Style TargetType="TextBox">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBox.Style>
                                </TextBox>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
