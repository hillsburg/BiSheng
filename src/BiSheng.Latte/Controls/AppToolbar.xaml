<UserControl
    x:Class="BiSheng.Latte.Controls.AppToolbar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:BiSheng.Latte.Converters"
    xmlns:ctrl="clr-namespace:BiSheng.Latte.Controls">

    <UserControl.Resources>
        <conv:HexColorToBrushConverter x:Key="HexColorToBrush" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />

        <Style x:Key="ToolbarButton" TargetType="Button">
            <Setter Property="Width" Value="36" />
            <Setter Property="Height" Value="36" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource Brush.ToolbarIcon}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="ToolTip" Value="{Binding Tag, RelativeSource={RelativeSource Self}}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            x:Name="Bd"
                            Background="{TemplateBinding Background}"
                            CornerRadius="6"
                            SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center">
                                <ContentPresenter.ContentTemplate>
                                    <DataTemplate>
                                        <TextBlock
                                            FontFamily="{Binding FontFamily, RelativeSource={RelativeSource AncestorType=Button}}"
                                            FontSize="{Binding FontSize, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                            Text="{Binding}" />
                                    </DataTemplate>
                                </ContentPresenter.ContentTemplate>
                            </ContentPresenter>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.ToolbarHover}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.Accent}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButtonVertical" TargetType="Button" BasedOn="{StaticResource ToolbarButton}">
            <Setter Property="Margin" Value="0,2" />
        </Style>

        <Style x:Key="ToolbarSeparatorHorizontal" TargetType="Border">
            <Setter Property="Width" Value="1" />
            <Setter Property="Height" Value="20" />
            <Setter Property="Margin" Value="6,0" />
            <Setter Property="Background" Value="{DynamicResource Brush.BorderLight}" />
        </Style>

        <Style x:Key="ToolbarSeparatorVertical" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="4,6" />
            <Setter Property="Background" Value="{DynamicResource Brush.BorderLight}" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <!--  顶部：左面板 | 右设置与窗口控制  -->
        <DockPanel Visibility="{Binding IsToolbarNavLeft, Converter={StaticResource InverseBoolToVis}}">
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                <Button
                    Command="{Binding ToggleFolderPanelCommand}"
                    Content="{StaticResource Icon.Collapse}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="切换导航面板" />
                <Button
                    Command="{Binding ToggleOutlinePanelCommand}"
                    Content="{StaticResource Icon.Outline}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="笔记大纲" />
                <Button
                    Command="{Binding OpenNoteHistoryCommand}"
                    Content="{StaticResource Icon.History}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="历史版本" />
                <Button
                    Command="{Binding OpenNoteSearchCommand}"
                    Content="{StaticResource Icon.Search}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="全文搜索 (Ctrl+Shift+F)" />
            </StackPanel>

            <StackPanel HorizontalAlignment="Right" DockPanel.Dock="Right" Orientation="Horizontal">
                <Button
                    Command="{Binding OpenAppearanceCommand}"
                    Content="{StaticResource Icon.Style}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="外观与样式设置" />
                <Button
                    Command="{Binding OpenTrashCommand}"
                    Content="{StaticResource Icon.Trash}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="回收站" />
                <Button
                    Command="{Binding OpenBackupManagerCommand}"
                    Content="{StaticResource Icon.Backup}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="本地备份" />
                <Button
                    Command="{Binding ExportFullLibraryCommand}"
                    Content="{StaticResource Icon.Export}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="导出全部库" />
                <Button
                    Command="{Binding OpenSyncSettingsCommand}"
                    Content="{StaticResource Icon.SyncSettings}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="同步与安全" />
                <Button
                    Command="{Binding ManualSyncCommand}"
                    Content="{StaticResource Icon.Sync2}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="手动同步" />
                <ctrl:ConnectionStatusBadge Margin="4,0" />
                <Button
                    Command="{Binding OpenAboutCommand}"
                    Content="{StaticResource Icon.About}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButton}"
                    Tag="关于与检查更新" />
                <Border Style="{StaticResource ToolbarSeparatorHorizontal}" />
                <!-- 窗口按钮：显式 ToolTip + UIFont，避免继承 Segoe MDL2 导致中文 tooltip 乱码 -->
                <Button
                    Command="{Binding MinimizeWindowCommand}"
                    Content="&#xE921;"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource ToolbarButton}">
                    <Button.ToolTip>
                        <ToolTip Content="最小化" FontFamily="{StaticResource UIFont}" />
                    </Button.ToolTip>
                </Button>
                <Button
                    Command="{Binding ToggleMaximizeWindowCommand}"
                    Content="{Binding MaximizeButtonGlyph}"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource ToolbarButton}">
                    <Button.ToolTip>
                        <ToolTip Content="{Binding MaximizeButtonTooltip}" FontFamily="{StaticResource UIFont}" />
                    </Button.ToolTip>
                </Button>
                <Button
                    Command="{Binding CloseWindowCommand}"
                    Content="&#xE8BB;"
                    FontFamily="Segoe MDL2 Assets"
                    Foreground="{DynamicResource Brush.Danger}"
                    Style="{StaticResource ToolbarButton}">
                    <Button.ToolTip>
                        <ToolTip Content="{Binding CloseWindowTooltip}" FontFamily="{StaticResource UIFont}" />
                    </Button.ToolTip>
                </Button>
            </StackPanel>
        </DockPanel>

        <!--  导航左侧：上→下 = 面板 / 应用 / 状态 / 窗口  -->
        <DockPanel
            Visibility="{Binding IsToolbarNavLeft, Converter={StaticResource BoolToVis}}"
            LastChildFill="True">
            <StackPanel HorizontalAlignment="Center" DockPanel.Dock="Top">
                <Button
                    Command="{Binding ToggleFolderPanelCommand}"
                    Content="{StaticResource Icon.Collapse}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="切换导航面板" />
                <Button
                    Command="{Binding ToggleOutlinePanelCommand}"
                    Content="{StaticResource Icon.Outline}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="笔记大纲" />
                <Button
                    Command="{Binding OpenNoteHistoryCommand}"
                    Content="{StaticResource Icon.History}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="历史版本" />
                <Button
                    Command="{Binding OpenNoteSearchCommand}"
                    Content="{StaticResource Icon.Search}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="全文搜索 (Ctrl+Shift+F)" />
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" DockPanel.Dock="Bottom">
                <Button
                    Command="{Binding CloseWindowCommand}"
                    Content="&#xE8BB;"
                    FontFamily="Segoe MDL2 Assets"
                    Foreground="{DynamicResource Brush.Danger}"
                    Style="{StaticResource ToolbarButtonVertical}">
                    <Button.ToolTip>
                        <ToolTip Content="{Binding CloseWindowTooltip}" FontFamily="{StaticResource UIFont}" />
                    </Button.ToolTip>
                </Button>
                <Button
                    Command="{Binding ToggleMaximizeWindowCommand}"
                    Content="{Binding MaximizeButtonGlyph}"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource ToolbarButtonVertical}">
                    <Button.ToolTip>
                        <ToolTip Content="{Binding MaximizeButtonTooltip}" FontFamily="{StaticResource UIFont}" />
                    </Button.ToolTip>
                </Button>
                <Button
                    Command="{Binding MinimizeWindowCommand}"
                    Content="&#xE921;"
                    FontFamily="Segoe MDL2 Assets"
                    Style="{StaticResource ToolbarButtonVertical}">
                    <Button.ToolTip>
                        <ToolTip Content="最小化" FontFamily="{StaticResource UIFont}" />
                    </Button.ToolTip>
                </Button>
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" DockPanel.Dock="Bottom">
                <Border Style="{StaticResource ToolbarSeparatorVertical}" />
                <ctrl:ConnectionStatusBadge Compact="True" Margin="0,4" />
                <Button
                    Command="{Binding OpenAboutCommand}"
                    Content="{StaticResource Icon.About}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="关于与检查更新" />
            </StackPanel>

            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <Button
                    Command="{Binding OpenAppearanceCommand}"
                    Content="{StaticResource Icon.Style}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="外观与样式设置" />
                <Button
                    Command="{Binding OpenTrashCommand}"
                    Content="{StaticResource Icon.Trash}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="回收站" />
                <Button
                    Command="{Binding OpenBackupManagerCommand}"
                    Content="{StaticResource Icon.Backup}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="本地备份" />
                <Button
                    Command="{Binding ExportFullLibraryCommand}"
                    Content="{StaticResource Icon.Export}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="导出全部库" />
                <Button
                    Command="{Binding OpenSyncSettingsCommand}"
                    Content="{StaticResource Icon.SyncSettings}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="同步与安全" />
                <Button
                    Command="{Binding ManualSyncCommand}"
                    Content="{StaticResource Icon.Sync2}"
                    FontFamily="{StaticResource IconFont}"
                    Style="{StaticResource ToolbarButtonVertical}"
                    Tag="手动同步" />
            </StackPanel>
        </DockPanel>
    </Grid>
</UserControl>
