<UserControl
    x:Class="BiSheng.Latte.Controls.ConnectionStatusBadge"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:BiSheng.Latte.Converters">

    <UserControl.Resources>
        <conv:ResourceKeyToBrushConverter x:Key="ResourceKeyToBrush" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>

    <!-- 统一连接入口：冲突时打开冲突窗，否则打开同步设置；底栏隐藏时仍靠此兜底 -->
    <Button
        Padding="6,4"
        Background="Transparent"
        BorderThickness="0"
        Command="{Binding OpenConnectionStatusCommand}"
        Cursor="Hand"
        ToolTip="{Binding ConnectionDisplay.DetailText}">
        <Button.Template>
            <ControlTemplate TargetType="Button">
                <Border
                    x:Name="Bd"
                    Padding="{TemplateBinding Padding}"
                    Background="{TemplateBinding Background}"
                    CornerRadius="6">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Brush.ToolbarHover}" />
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>
        </Button.Template>
        <StackPanel Orientation="Horizontal">
            <TextBlock
                VerticalAlignment="Center"
                FontFamily="Segoe MDL2 Assets"
                FontSize="14"
                Foreground="{Binding ConnectionDisplay.BrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                Text="{Binding ConnectionDisplay.IconGlyph}" />
            <TextBlock
                Margin="6,0,0,0"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{Binding ConnectionDisplay.BrushKey, Converter={StaticResource ResourceKeyToBrush}}"
                Text="{Binding ConnectionDisplay.ShortLabel}"
                Visibility="{Binding Compact, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource InverseBoolToVis}}" />
        </StackPanel>
    </Button>
</UserControl>
