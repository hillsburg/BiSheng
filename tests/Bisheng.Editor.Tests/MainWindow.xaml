<Window x:Class="BiSheng.Editor.Tests.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:md="clr-namespace:BiSheng.Editor.Controls.MarkdownEditor;assembly=BiSheng.Editor"
        xmlns:theme="clr-namespace:BiSheng.Editor.Controls.MarkdownEditor.Themes;assembly=BiSheng.Editor"
        mc:Ignorable="d"
        Title="BiSheng 渲染引擎测试"
        Height="800" Width="1200"
        Background="#F0F0F0">

    <Window.Resources>
        <Style x:Key="TestSectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Margin" Value="0,8,0,4"/>
        </Style>
        <Style x:Key="TestButton" TargetType="Button">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="13"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#106EBE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatusBadge" TargetType="Border">
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="Margin" Value="4,0"/>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- 顶部控制栏 -->
        <Border DockPanel.Dock="Top"
                Background="White"
                BorderBrush="#DDD"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="BiSheng 渲染引擎测试工具"
                               FontSize="18" FontWeight="Bold"
                               Foreground="#333" VerticalAlignment="Center"/>
                    <Border Style="{StaticResource StatusBadge}"
                            Background="#E8F5E9" Margin="12,0,0,0">
                        <TextBlock x:Name="StatusText"
                                   Text="就绪"
                                   Foreground="#2E7D32"
                                   FontSize="12"/>
                    </Border>
                </StackPanel>
                <WrapPanel>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试1: 基础语法"
                            Click="OnTestBasicSyntax"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试2: 行内样式"
                            Click="OnTestInlineStyles"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试3: 列表"
                            Click="OnTestLists"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试4: 代码块"
                            Click="OnTestCodeBlocks"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试5: 引用块"
                            Click="OnTestBlockQuotes"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试6: 图片"
                            Click="OnTestImages"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试7: 综合文档"
                            Click="OnTestFullDocument"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试8: 深色主题"
                            Click="OnTestDarkTheme"
                            Background="#424242"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试9: 浅色主题"
                            Click="OnTestLightTheme"
                            Background="#E0E0E0"
                            Foreground="#333"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试10: 空文档"
                            Click="OnTestEmptyDocument"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试11: 超长文档"
                            Click="OnTestLongDocument"
                            Background="#FF6F00"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="测试12: 特殊字符"
                            Click="OnTestSpecialChars"
                            Background="#7B1FA2"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="字体大小 +"
                            Click="OnFontSizeUp"
                            Background="#00695C"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="字体大小 -"
                            Click="OnFontSizeDown"
                            Background="#00695C"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="行间距 +"
                            Click="OnLineSpacingUp"
                            Background="#1565C0"/>
                    <Button Style="{StaticResource TestButton}"
                            Content="行间距 -"
                            Click="OnLineSpacingDown"
                            Background="#1565C0"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <!-- 底部信息栏 -->
        <Border DockPanel.Dock="Bottom"
                Background="#F5F5F5"
                BorderBrush="#DDD"
                BorderThickness="0,1,0,0"
                Padding="12,6">
            <StackPanel Orientation="Horizontal">
                <TextBlock x:Name="LineInfo"
                           Text="行: 1"
                           Foreground="#666"
                           FontSize="12"
                           Margin="0,0,16,0"/>
                <TextBlock x:Name="ColInfo"
                           Text="列: 1"
                           Foreground="#666"
                           FontSize="12"
                           Margin="0,0,16,0"/>
                <TextBlock x:Name="CharCount"
                           Text="字符: 0"
                           Foreground="#666"
                           FontSize="12"
                           Margin="0,0,16,0"/>
                <TextBlock x:Name="RenderTime"
                           Text="渲染: -"
                           Foreground="#666"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <!-- 主编辑区域 -->
        <Grid Margin="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Border Background="White"
                    BorderBrush="#DDD"
                    BorderThickness="1"
                    CornerRadius="4">
                <md:MarkdownEditorControl x:Name="TestEditor"/>
            </Border>
        </Grid>
    </DockPanel>
</Window>
